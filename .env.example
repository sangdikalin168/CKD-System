# ─── Database ────────────────────────────────────────────────────────────────
# Use 'db' to connect to the bundled MySQL container.
# Replace with your external host/IP if you already have a MySQL server.
DB_HOST=db
DB_USER=admin
DB_PASSWORD=changeme
DB_NAME=sportclub

# Root password for the bundled MySQL container
MYSQL_ROOT_PASSWORD=changeme_root

# ─── Security ─────────────────────────────────────────────────────────────────
# Generate strong random values for production, e.g.:
#   openssl rand -hex 32
ACCESS_TOKEN_SECRET=changeme_access_secret
REFRESH_TOKEN_SECRET=changeme_refresh_secret
REFRESH_TOKEN_COOKIE_NAME=connect.sid

# ─── CORS ─────────────────────────────────────────────────────────────────────
# '*' allows all origins (fine when nginx fronts everything on the same domain).
# For stricter setups use a comma-separated list: http://myserver.com,https://myserver.com
CORS_ORIGIN=*

# ─── Frontend ─────────────────────────────────────────────────────────────────
# '/graphql' works when nginx proxies the API (default docker-compose setup).
# Change to an absolute URL if you expose the backend directly, e.g.:
#   VITE_API_URL=http://myserver.com:4000/graphql
# NOTE: changing this requires rebuilding the frontend image.
VITE_API_URL=/graphql

# ─── Port ─────────────────────────────────────────────────────────────────────
# Host port that nginx listens on (localhost only — Cloudflare Tunnel handles external traffic).
APP_PORT=80

# ─── Cloudflare Tunnel ────────────────────────────────────────────────────────
# Token from: Cloudflare Dashboard → Zero Trust → Networks → Tunnels → your tunnel → Configure
CLOUDFLARE_TUNNEL_TOKEN=your_tunnel_token_here
